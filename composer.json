{
    "name": "lukk/lukk",
    "description": "Minimal-dependency JWT auth for first-party Laravel apps (unofficial; not affiliated with the Laravel team): short access tokens, opaque rotating refresh tokens, reuse detection, grace window, and instant denylist revocation.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/stsepelin/lukk",
    "keywords": ["laravel", "auth", "authentication", "jwt", "refresh-token", "passkey", "webauthn", "2fa", "totp"],
    "authors": [
        {
            "name": "Aleksand Štšepelin",
            "email": "as@jp.ee"
        }
    ],
    "support": {
        "issues": "https://github.com/stsepelin/lukk/issues",
        "source": "https://github.com/stsepelin/lukk"
    },
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^7.0",
        "illuminate/auth": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pragmarx/google2fa": "^9.0",
        "web-auth/webauthn-lib": "^5.0",
        "pronin/webauthn-emulator": "^1.2"
    },
    "suggest": {
        "pragmarx/google2fa": "Required for the two-factor (TOTP) feature — enable features.two_factor.",
        "web-auth/webauthn-lib": "Required for the passkeys feature — enable features.passkeys (the default WebAuthnCeremony wraps it)."
    },
    "autoload": {
        "psr-4": {
            "Lukk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lukk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lukk\\LukkServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
