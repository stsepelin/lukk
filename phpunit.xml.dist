<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
    bootstrap="vendor/autoload.php"
    colors="true"
>
    <testsuites>
        <testsuite name="Lukk Test Suite">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <!-- Scope coverage to the package source so a never-loaded class is reported
         as a gap, not silently excluded. Test environment is configured in
         tests/TestCase.php (Testbench), not here. -->
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
